[sub_resource type="GDScript" id="GDScript_6pu0d"]
resource_name = "animationTreeInterface"
script/source = "extends Node3D

@onready var anim_tree: AnimationTree = $bert/AnimationTreeStateMachine

func _ready() -> void:
	if anim_tree == null:
		push_error(\"Bertmodel: AnimationTreeStateMachine not found at bert/AnimationTreeStateMachine\")
		return
	anim_tree.active = true
	setSteer(0.5)
	_mark_no_paint(self)

func _mark_no_paint(node: Node) -> void:
	if node is MeshInstance3D:
		node.add_to_group(\"NoPaint\")
	for child in node.get_children():
		_mark_no_paint(child)

func _playback() -> AnimationNodeStateMachinePlayback:
	return anim_tree[\"parameters/playback\"] as AnimationNodeStateMachinePlayback

func setSteer(f: float) -> void:
	if f > 1 or f < 0:
		return
	anim_tree[\"parameters/locomotion/boardBlendMichael/blend_amount\"] = f
	

func start_moving() -> void:
	anim_tree[\"parameters/conditions/is_moving\"] = true
	anim_tree[\"parameters/conditions/is_idle\"] = false
	anim_tree[\"parameters/conditions/is_landing\"] = false
	_playback().travel(\"locomotion\")

func start_idling() -> void:
	anim_tree[\"parameters/conditions/is_idle\"] = true
	anim_tree[\"parameters/conditions/is_moving\"] = false
	anim_tree[\"parameters/conditions/is_landing\"] = false
	_playback().travel(\"IdleStanding\")

func start_jump() -> void:
	anim_tree[\"parameters/conditions/is_jumping\"] = true
	anim_tree[\"parameters/conditions/is_landing\"] = false
	anim_tree[\"parameters/conditions/is_grinding\"] = false
	_playback().travel(\"jumpStart\")

func land() -> void:
	var current := _playback().get_current_node()
	if current == \"inAir\" or current == \"jumpStart\":
		anim_tree[\"parameters/conditions/is_landing\"] = true
		anim_tree[\"parameters/conditions/is_jumping\"] = false
		_playback().start(\"jumpEnd\")

func start_grind() -> void:
	anim_tree[\"parameters/conditions/is_grinding\"] = true
	anim_tree[\"parameters/conditions/is_jumping\"] = false
	anim_tree[\"parameters/conditions/is_landing\"] = false
	_playback().start(\"grindRail\")

func stop_grind() -> void:
	anim_tree[\"parameters/conditions/is_grinding\"] = false
	_playback().travel(\"locomotion\")
	
func do_trick_1() -> void:
	_playback().start(\"trick1\")
	
func do_trick_2() -> void:
	_playback().start(\"trick2\")
"

